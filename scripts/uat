#!/usr/bin/env bash
#
# uat - Matrix-driven integration test runner
#
# Reads test-matrix.yaml for host-to-manifest assignments, SSHes to each
# target host, runs iac-driver manifest tests, and produces an aggregated
# pass/fail summary.
#
# Usage:
#   uat [options]
#
# Options:
#   --mode uat|sprint    uat = manifest test, sprint = manifest apply (default: uat)
#   --branch NAME        Deploy sprint branches to target hosts before testing
#   --provision          Full pipeline: reinstall -> bootstrap -> site-init ->
#                        pve-setup -> images -> test matrix
#   --matrix FILE        Matrix file (default: <meta>/test-matrix.yaml)
#   --host NAME          Filter: run only this host from matrix
#   --manifest NAME      Filter: run only this manifest
#   --verbose            Pass --verbose to iac-driver
#   --dry-run            Show what would run without executing
#   --help               Show help
#
# Exit codes:
#   0  All manifests passed
#   1  One or more manifests failed
#   2  Setup error (bad matrix, SSH failure, provisioning failure)
#

set -euo pipefail

# -----------------------------------------------------------------------------
# Configuration
# -----------------------------------------------------------------------------

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
META_DIR="$(dirname "$SCRIPT_DIR")"
WORKSPACE_DIR="${WORKSPACE_DIR:-$(cd "$META_DIR/../.." && pwd)}"
CONFIG_DIR="${WORKSPACE_DIR}/config"
LOG_DIR="${WORKSPACE_DIR}/logs"
DEFAULT_MATRIX="${META_DIR}/test-matrix.yaml"
BOOTSTRAP_URL="https://raw.githubusercontent.com/homestak/bootstrap/master/install"

# Provisioning stage timeouts (seconds) — override via environment
TIMEOUT_REINSTALL="${TIMEOUT_REINSTALL:-900}"     # 15 min
TIMEOUT_BOOTSTRAP="${TIMEOUT_BOOTSTRAP:-600}"     # 10 min
TIMEOUT_SITE_INIT="${TIMEOUT_SITE_INIT:-300}"     # 5 min
TIMEOUT_PVE_SETUP="${TIMEOUT_PVE_SETUP:-600}"     # 10 min
TIMEOUT_IMAGES="${TIMEOUT_IMAGES:-600}"           # 10 min

# SSH options for automation (no host key prompts, quiet)
SSH_OPTS="-o StrictHostKeyChecking=accept-new -o UserKnownHostsFile=/dev/null -o LogLevel=ERROR"

# Global state for trap handler (populated in main)
_RUN_ID=""
_MODE=""
_BRANCH=""
_STARTED_AT=""
_RESULTS_JSON="[]"
_INTERRUPTED=false

# -----------------------------------------------------------------------------
# Colors and Logging
# -----------------------------------------------------------------------------

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log_info()    { echo -e "${BLUE}[$(date +%H:%M:%S)] [INFO]${NC} $*" >&2; }
log_success() { echo -e "${GREEN}[$(date +%H:%M:%S)] [OK]${NC} $*" >&2; }
log_warn()    { echo -e "${YELLOW}[$(date +%H:%M:%S)] [WARN]${NC} $*" >&2; }
log_error()   { echo -e "${RED}[$(date +%H:%M:%S)] [ERROR]${NC} $*" >&2; }

# -----------------------------------------------------------------------------
# Help
# -----------------------------------------------------------------------------

usage() {
    cat <<'EOF'
uat - Matrix-driven integration test runner

Usage:
  uat [options]

Options:
  --mode uat|sprint    Execution mode (default: uat)
                       uat    = manifest test (create -> verify -> destroy)
                       sprint = manifest apply (create -> verify, stop on failure)
  --branch NAME        Deploy sprint branches to target hosts before testing
  --provision          Full pipeline: reinstall -> bootstrap -> site-init ->
                       pve-setup -> images -> test matrix
  --matrix FILE        Matrix file (default: <meta>/test-matrix.yaml)
  --host NAME          Filter: run only this host from matrix
  --manifest NAME      Filter: run only this manifest
  --verbose            Pass --verbose to iac-driver
  --dry-run            Show what would run without executing
  --help               Show help

Exit codes:
  0  All manifests passed
  1  One or more manifests failed
  2  Setup error (bad matrix, SSH failure, provisioning failure)

Examples:
  uat                              # Run the full matrix
  uat --mode sprint                # Apply mode (stop on failure)
  uat --branch sprint/foo          # Deploy branches first
  uat --host srv1 --manifest n1-push  # Filter to one test
  uat --provision                  # Full pipeline from reinstall
EOF
    exit 0
}

# -----------------------------------------------------------------------------
# Matrix Parsing
# -----------------------------------------------------------------------------

# Parse YAML matrix file into "host:manifest" lines via Python
# Reads: matrix file path from $1
# Outputs: one "host manifest" line per assignment to stdout
parse_matrix() {
    local matrix_file="$1"

    if [[ ! -f "$matrix_file" ]]; then
        log_error "Matrix file not found: $matrix_file"
        exit 2
    fi

    python3 -c "
import yaml, sys
data = yaml.safe_load(open(sys.argv[1]))
matrix = data.get('matrix', {})
if not matrix:
    print('ERROR: empty matrix', file=sys.stderr)
    sys.exit(1)
for host, manifests in matrix.items():
    if not isinstance(manifests, list):
        manifests = [manifests]
    for m in manifests:
        print(f'{host} {m}')
" "$matrix_file"
}

# Validate that all manifest names in the matrix exist in config
validate_manifests() {
    local matrix_file="$1"
    local invalid=()

    while IFS=' ' read -r _host manifest; do
        if [[ ! -f "${CONFIG_DIR}/manifests/${manifest}.yaml" ]]; then
            # Deduplicate
            local already=false
            for inv in "${invalid[@]+"${invalid[@]}"}"; do
                [[ "$inv" == "$manifest" ]] && already=true
            done
            $already || invalid+=("$manifest")
        fi
    done < <(parse_matrix "$matrix_file")

    if [[ ${#invalid[@]} -gt 0 ]]; then
        log_error "Unknown manifest(s): ${invalid[*]}"
        local available
        available=$(find "${CONFIG_DIR}/manifests" -name 'n*.yaml' -exec basename {} .yaml \; 2>/dev/null | sort | tr '\n' ' ')
        log_error "Available: ${available:-none}"
        exit 2
    fi
}

# -----------------------------------------------------------------------------
# SSH Helpers
# -----------------------------------------------------------------------------

# Run a command on a remote host as the homestak user
# Uses bash -l (login shell) so ~/.profile is sourced and PATH includes homestak CLI
# Heredoc-over-SSH avoids quoting issues with single quotes in commands
run_on_host() {
    local host="$1"
    local cmd="$2"
    # shellcheck disable=SC2086,SC2029,SC2087
    ssh $SSH_OPTS "${USER}@${host}" "sudo -u homestak bash -l" <<REMOTECMD
${cmd}
REMOTECMD
}

# Run a command on a remote host as the current user (for sudo operations)
run_on_host_as_user() {
    local host="$1"
    local cmd="$2"
    # shellcheck disable=SC2086
    ssh $SSH_OPTS "${USER}@${host}" "$cmd"
}

# Wait for SSH to become available after reboot
wait_for_ssh() {
    local host="$1"
    local timeout="${2:-300}"
    local interval="${3:-15}"
    local start elapsed

    start=$(date +%s)
    log_info "Waiting for SSH on ${host} (timeout: ${timeout}s)..."

    while true; do
        elapsed=$(( $(date +%s) - start ))
        if [[ $elapsed -ge $timeout ]]; then
            log_error "SSH timeout waiting for ${host} after ${timeout}s"
            return 1
        fi

        # shellcheck disable=SC2086
        if ssh $SSH_OPTS -o ConnectTimeout=5 "${USER}@${host}" "echo ready" &>/dev/null; then
            log_success "SSH available on ${host} (${elapsed}s)"
            return 0
        fi

        sleep "$interval"
    done
}

# -----------------------------------------------------------------------------
# Provisioning Pipeline
# -----------------------------------------------------------------------------

provision_host() {
    local host="$1"

    log_info "=== Provisioning ${host} ==="

    # Step 1: Reinstall via bare-metal
    log_info "[1/5] Reinstalling ${host} (timeout: ${TIMEOUT_REINSTALL}s)..."
    if ! timeout "$TIMEOUT_REINSTALL" "${WORKSPACE_DIR}/bare-metal/reinstall" "$host" --yes; then
        log_error "Reinstall failed or timed out for ${host}"
        return 1
    fi

    # Remove stale host key after reinstall
    ssh-keygen -R "$host" 2>/dev/null || true

    # Wait for fresh host SSH
    if ! wait_for_ssh "$host" 600 15; then
        log_error "Host ${host} not reachable after reinstall"
        return 1
    fi

    # Step 2: Bootstrap
    log_info "[2/5] Bootstrapping ${host} (timeout: ${TIMEOUT_BOOTSTRAP}s)..."
    # shellcheck disable=SC2086
    if ! timeout "$TIMEOUT_BOOTSTRAP" ssh $SSH_OPTS "${USER}@${host}" \
        "curl -fsSL ${BOOTSTRAP_URL} | sudo bash -s -- --skip-apt-wait"; then
        log_error "Bootstrap failed or timed out on ${host}"
        return 1
    fi

    # Step 3: Site init
    log_info "[3/5] Running site-init on ${host} (timeout: ${TIMEOUT_SITE_INIT}s)..."
    if ! timeout "$TIMEOUT_SITE_INIT" run_on_host "$host" "homestak site-init"; then
        log_error "site-init failed or timed out on ${host}"
        return 1
    fi

    # Step 4: PVE setup (handles reboot)
    log_info "[4/5] Running pve-setup on ${host} (timeout: ${TIMEOUT_PVE_SETUP}s)..."
    local rc=0
    set +e
    timeout "$TIMEOUT_PVE_SETUP" run_on_host "$host" "homestak pve-setup"
    rc=$?
    set -e

    if [[ $rc -eq 124 ]]; then
        log_error "pve-setup timed out on ${host}"
        return 1
    elif [[ $rc -eq 255 ]]; then
        # SSH disconnect likely means reboot
        log_info "SSH disconnected — waiting for reboot..."
        wait_for_ssh "$host" 600 15
        log_info "Re-running pve-setup after reboot..."
        if ! timeout "$TIMEOUT_PVE_SETUP" run_on_host "$host" "homestak pve-setup"; then
            log_error "pve-setup failed on ${host} after reboot"
            return 1
        fi
    elif [[ $rc -ne 0 ]]; then
        log_error "pve-setup failed on ${host} (exit ${rc})"
        return 1
    fi

    # Step 5: Download and publish packer images
    log_info "[5/5] Downloading images on ${host} (timeout: ${TIMEOUT_IMAGES}s)..."
    if ! timeout "$TIMEOUT_IMAGES" run_on_host "$host" "homestak images download all --publish"; then
        log_error "Image download failed or timed out on ${host}"
        return 1
    fi

    log_success "Provisioning complete for ${host}"
}

# -----------------------------------------------------------------------------
# Branch Deployment
# -----------------------------------------------------------------------------

deploy_branch() {
    local host="$1"
    local branch="$2"

    log_info "Deploying branch '${branch}' to ${host}..."
    run_on_host "$host" "homestak update --branch ${branch}"
}

# -----------------------------------------------------------------------------
# Test Execution
# -----------------------------------------------------------------------------

# Run a single manifest test on a host
# Returns: 0 on success, 1 on failure
# Outputs: JSON result to stdout
run_manifest_test() {
    local host="$1"
    local manifest="$2"
    local mode="$3"
    local verbose="$4"

    local verb="test"
    [[ "$mode" == "sprint" ]] && verb="apply"

    local verbose_flag=""
    [[ "$verbose" == "true" ]] && verbose_flag="--verbose"

    local cmd="cd ~/iac/iac-driver && ./run.sh manifest ${verb} -M ${manifest} -H \$(hostname -s) --json-output ${verbose_flag}"

    local json rc=0
    set +e
    json=$(run_on_host "$host" "$cmd" 2>/dev/null)
    rc=$?
    set -e

    # Output the captured JSON (or synthesize on SSH failure)
    if [[ -n "$json" ]]; then
        echo "$json"
    else
        # SSH or command failed without JSON output
        cat <<EJSON
{"verb":"${verb}","success":false,"duration_seconds":0,"nodes":[],"error":"SSH or command failed (exit ${rc})"}
EJSON
    fi

    return $rc
}

# -----------------------------------------------------------------------------
# Reporting
# -----------------------------------------------------------------------------

# Build the matrix summary JSON
build_summary() {
    local mode="$1"
    local branch="$2"
    local run_id="$3"
    local started_at="$4"
    local finished_at="$5"
    local results_json="$6"    # JSON array string

    local total_duration passed failed all_passed hosts_json

    # Calculate duration
    local start_epoch end_epoch
    start_epoch=$(date -d "$started_at" +%s 2>/dev/null || date +%s)
    end_epoch=$(date -d "$finished_at" +%s 2>/dev/null || date +%s)
    total_duration=$(( end_epoch - start_epoch ))

    # Count results
    passed=$(echo "$results_json" | jq '[.[] | select(.status == "passed")] | length')
    failed=$(echo "$results_json" | jq '[.[] | select(.status != "passed")] | length')
    all_passed="false"
    [[ "$failed" -eq 0 && "$_INTERRUPTED" == "false" ]] && all_passed="true"

    # Unique hosts
    hosts_json=$(echo "$results_json" | jq '[.[].host] | unique')

    jq -n \
        --arg run_id "$run_id" \
        --arg mode "$mode" \
        --arg branch "$branch" \
        --argjson hosts "$hosts_json" \
        --arg started_at "$started_at" \
        --arg finished_at "$finished_at" \
        --argjson results "$results_json" \
        --argjson total_duration "$total_duration" \
        --argjson passed "$passed" \
        --argjson failed "$failed" \
        --argjson all_passed "$all_passed" \
        --argjson interrupted "$_INTERRUPTED" \
        '{
            run_id: $run_id,
            mode: $mode,
            branch: $branch,
            hosts: $hosts,
            started_at: $started_at,
            finished_at: $finished_at,
            results: $results,
            total_duration: $total_duration,
            passed: $passed,
            failed: $failed,
            all_passed: $all_passed,
            interrupted: $interrupted
        }'
}

# Print the summary table to stderr
print_summary() {
    local summary_json="$1"

    local mode branch passed failed total all_passed total_duration
    mode=$(echo "$summary_json" | jq -r '.mode')
    branch=$(echo "$summary_json" | jq -r '.branch')
    passed=$(echo "$summary_json" | jq -r '.passed')
    failed=$(echo "$summary_json" | jq -r '.failed')
    total=$(( passed + failed ))
    all_passed=$(echo "$summary_json" | jq -r '.all_passed')
    total_duration=$(echo "$summary_json" | jq -r '.total_duration')

    local mins secs
    mins=$(( total_duration / 60 ))
    secs=$(( total_duration % 60 ))

    echo "" >&2
    echo "================================================================" >&2
    echo "  Matrix Results — $(date '+%Y-%m-%d %H:%M:%S')" >&2
    echo "  Mode: ${mode}  Branch: ${branch}" >&2
    echo "================================================================" >&2
    echo "" >&2

    # Table header
    printf "  %-12s %-12s %-10s %s\n" "Host" "Manifest" "Status" "Duration" >&2
    printf "  %-12s %-12s %-10s %s\n" "----" "--------" "------" "--------" >&2

    # Table rows
    echo "$summary_json" | jq -r '.results[] | "\(.host) \(.manifest) \(.status) \(.duration)"' | \
    while IFS=' ' read -r host manifest status duration; do
        local color="$GREEN"
        local label="PASSED"
        if [[ "$status" != "passed" ]]; then
            color="$RED"
            label="FAILED"
        fi
        printf "  %-12s %-12s ${color}%-10s${NC} %ss\n" "$host" "$manifest" "$label" "$duration" >&2
    done

    echo "" >&2
    if [[ "$all_passed" == "true" ]]; then
        echo -e "  ${GREEN}${passed}/${total} passed${NC} — Total: ${mins}m ${secs}s" >&2
    else
        echo -e "  ${RED}${passed}/${total} passed (${failed} failed)${NC} — Total: ${mins}m ${secs}s" >&2
    fi
    echo "" >&2
}

# Write summary to log directory
write_summary() {
    local summary_json="$1"
    local run_id branch status filename

    run_id=$(echo "$summary_json" | jq -r '.run_id')

    mkdir -p "$LOG_DIR"
    filename="${LOG_DIR}/${run_id}.matrix.json"
    echo "$summary_json" | jq '.' > "$filename"
    log_info "Summary: ${filename}"
}

# -----------------------------------------------------------------------------
# Interrupt Handler
# -----------------------------------------------------------------------------

# Write partial results on SIGINT/SIGTERM
handle_interrupt() {
    _INTERRUPTED=true

    # Restore stderr to original terminal — tee may be dead from SIGINT
    exec 2>&3 2>/dev/null || true

    echo "" >&2
    log_warn "Interrupted — writing partial results..."

    if [[ -n "$_RUN_ID" ]]; then
        local finished_at summary
        finished_at=$(date -Iseconds)
        summary=$(build_summary "$_MODE" "$_BRANCH" "$_RUN_ID" "$_STARTED_AT" "$finished_at" "$_RESULTS_JSON")
        print_summary "$summary"
        write_summary "$summary"

        # Append to log file directly (tee is dead)
        local log_file="${LOG_DIR}/${_RUN_ID}.uat.log"
        echo "[$(date +%H:%M:%S)] [WARN] Interrupted — partial results written" >> "$log_file" 2>/dev/null || true
    fi

    exit 130  # 128 + SIGINT(2)
}

# -----------------------------------------------------------------------------
# Main
# -----------------------------------------------------------------------------

main() {
    local mode="uat"
    local branch=""
    local provision=false
    local matrix_file="$DEFAULT_MATRIX"
    local filter_host=""
    local filter_manifest=""
    local verbose=false
    local dry_run=false

    # --- Parse flags ---
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --mode)
                mode="$2"
                if [[ "$mode" != "uat" && "$mode" != "sprint" ]]; then
                    log_error "Invalid mode: $mode (must be 'uat' or 'sprint')"
                    exit 2
                fi
                shift 2
                ;;
            --branch)     branch="$2"; shift 2 ;;
            --provision)  provision=true; shift ;;
            --matrix)     matrix_file="$2"; shift 2 ;;
            --host)       filter_host="$2"; shift 2 ;;
            --manifest)   filter_manifest="$2"; shift 2 ;;
            --verbose)    verbose=true; shift ;;
            --dry-run)    dry_run=true; shift ;;
            --help|-h)    usage ;;
            *)
                log_error "Unknown option: $1"
                exit 2
                ;;
        esac
    done

    # --- Check dependencies ---
    for cmd in ssh jq python3; do
        if ! command -v "$cmd" &>/dev/null; then
            log_error "Required tool not found: $cmd"
            exit 2
        fi
    done

    # --- Load and validate matrix ---
    log_info "Loading matrix from ${matrix_file}..."
    local assignments=()
    while IFS=' ' read -r host manifest; do
        # Apply filters
        [[ -n "$filter_host" && "$host" != "$filter_host" ]] && continue
        [[ -n "$filter_manifest" && "$manifest" != "$filter_manifest" ]] && continue
        assignments+=("${host}:${manifest}")
    done < <(parse_matrix "$matrix_file")

    if [[ ${#assignments[@]} -eq 0 ]]; then
        log_error "No tests to run (check matrix file and filters)"
        exit 2
    fi

    validate_manifests "$matrix_file"

    # Determine branch
    if [[ -z "$branch" ]]; then
        branch=$(git -C "$META_DIR" branch --show-current 2>/dev/null || echo "master")
    fi
    _BRANCH="$branch"

    # --- Dry run ---
    if $dry_run; then
        echo "" >&2
        echo "Dry run — no tests will be executed." >&2
        echo "" >&2
        echo "  Mode:     ${mode}" >&2
        echo "  Branch:   ${branch}" >&2
        echo "  Matrix:   ${matrix_file}" >&2
        echo "  Provision: ${provision}" >&2
        echo "" >&2
        printf "  %-12s %s\n" "Host" "Manifest" >&2
        printf "  %-12s %s\n" "----" "--------" >&2
        for entry in "${assignments[@]}"; do
            IFS=':' read -r host manifest <<< "$entry"
            printf "  %-12s %s\n" "$host" "$manifest" >&2
        done
        echo "" >&2
        echo "  Total: ${#assignments[@]} test(s)" >&2
        echo "" >&2
        exit 0
    fi

    # --- Run ID and timestamps ---
    _RUN_ID=$(date '+%Y%m%d-%H%M%S')
    _MODE="$mode"
    _STARTED_AT=$(date -Iseconds)
    _RESULTS_JSON="[]"

    # --- Log to file ---
    # Save original stderr (fd 3) before tee redirect — trap handler restores it
    # when tee is killed by SIGINT
    mkdir -p "$LOG_DIR"
    local log_file="${LOG_DIR}/${_RUN_ID}.uat.log"
    exec 3>&2
    exec 2> >(tee -a "$log_file" >&3)
    log_info "Log file: ${log_file}"

    log_info "Matrix run ${_RUN_ID}: ${#assignments[@]} test(s), mode=${mode}, branch=${branch}"

    # Install interrupt handler (after globals are populated)
    trap handle_interrupt INT TERM

    # --- Collect unique hosts ---
    local -A hosts_seen
    local unique_hosts=()
    for entry in "${assignments[@]}"; do
        IFS=':' read -r host _ <<< "$entry"
        if [[ -z "${hosts_seen[$host]:-}" ]]; then
            hosts_seen[$host]=1
            unique_hosts+=("$host")
        fi
    done

    # --- Provision hosts (if requested) ---
    if $provision; then
        for host in "${unique_hosts[@]}"; do
            if ! provision_host "$host"; then
                log_error "Provisioning failed for ${host} — aborting"
                exit 2
            fi
        done
    fi

    # --- Deploy branches (if requested) ---
    if [[ -n "$branch" && "$branch" != "master" ]]; then
        for host in "${unique_hosts[@]}"; do
            deploy_branch "$host" "$branch"
        done
    fi

    # --- Execute tests ---
    local any_failed=false

    for entry in "${assignments[@]}"; do
        IFS=':' read -r host manifest <<< "$entry"

        log_info "Testing ${manifest} on ${host}..."
        local test_start test_end duration json rc=0 status

        test_start=$(date +%s)

        set +e
        json=$(run_manifest_test "$host" "$manifest" "$mode" "$verbose")
        rc=$?
        set -e

        test_end=$(date +%s)
        duration=$(( test_end - test_start ))

        if [[ $rc -eq 0 ]]; then
            status="passed"
            log_success "${manifest} on ${host}: PASSED (${duration}s)"
        else
            status="failed"
            any_failed=true
            log_error "${manifest} on ${host}: FAILED (${duration}s)"
        fi

        # Append result to global array (accessible to trap handler)
        _RESULTS_JSON=$(echo "$_RESULTS_JSON" | jq \
            --arg host "$host" \
            --arg manifest "$manifest" \
            --arg status "$status" \
            --argjson duration "$duration" \
            --argjson exit_code "$rc" \
            '. + [{host: $host, manifest: $manifest, status: $status, duration: $duration, exit_code: $exit_code}]')

        # Sprint mode: stop on first failure
        if [[ "$mode" == "sprint" && "$status" != "passed" ]]; then
            log_warn "Sprint mode — stopping after failure"
            break
        fi
    done

    # --- Build and write summary ---
    local finished_at summary
    finished_at=$(date -Iseconds)
    summary=$(build_summary "$_MODE" "$_BRANCH" "$_RUN_ID" "$_STARTED_AT" "$finished_at" "$_RESULTS_JSON")

    print_summary "$summary"
    write_summary "$summary"

    # --- Exit code ---
    if $any_failed; then
        exit 1
    fi
    exit 0
}

main "$@"
